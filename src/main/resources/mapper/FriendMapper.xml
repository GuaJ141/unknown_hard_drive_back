<!--            <foreach collection="friendIds" item="friend" open="(" separator="," close=")">-->
<!--                #{friend.friendId}-->
<!--            </foreach>-->
<!--            and username LIKE concat('%', #{input}, '%')-->
<!--            or unique_id = #{input};-->
<!--    </select>-->
</mapper>