<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unknownharddrivesystem.mapper.HdCommentMapper">
    <select id="selectComment" resultType="hdComment">
        select * from hd_comment
            where post_id = #{postId} and status = '1' order by comment_time desc
    </select>

    <insert id="Comment" parameterType="hdComment">
        INSERT INTO hd_comment (`comment_time`, `comment`, `username`, `post_id`)
                VALUES
                    (#{commentTime}, #{comment}, #{username}, #{postId})
    </insert>

    <update id="delComment" >
        UPDATE hd_comment SET `status` = '0' WHERE `id` = #{commentId}
    </update>
</mapper>